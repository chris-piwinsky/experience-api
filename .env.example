# Experience API local environment

# API server port
PORT=3000

# Enable deterministic mock behavior
MOCK_MODE=true

# Inventory scenario options: success | out_of_stock | timeout
MOCK_INVENTORY_SCENARIO=success

# Payment scenario options: success | declined | timeout
MOCK_PAYMENT_SCENARIO=success

# Fulfillment scenario options: success | timeout
MOCK_FULFILLMENT_SCENARIO=success

# Optional artificial delays in milliseconds
MOCK_INVENTORY_DELAY_MS=0
MOCK_PAYMENT_DELAY_MS=0
MOCK_FULFILLMENT_DELAY_MS=0
