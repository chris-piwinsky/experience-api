                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-request-id", "value": "{{requestId}}" },
                  { "key": "x-correlation-id", "value": "{{correlationId}}" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"payload\": {\n    \"firstName\": \"Sam\",\n    \"lastName\": \"Taylor\",\n    \"line1\": \"101 Main St\",\n    \"city\": \"Austin\",\n    \"state\": \"TX\",\n    \"postalCode\": \"78701\",\n    \"country\": \"US\"\n  }\n}" },
                "url": "{{baseUrl}}/v1/checkout/journeys/{{journeyId}}/steps/shipping-address"
              }
            },
