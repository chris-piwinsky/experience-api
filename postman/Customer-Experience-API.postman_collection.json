          "request": {
            "method": "POST",
            "header": [
              { "key": "x-request-id", "value": "{{requestId}}" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "url": "{{baseUrl}}/v1/checkout/journeys/{{journeyId}}/submit"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 503', () => pm.response.to.have.status(503));", "const json = pm.response.json();", "pm.test('error code is FULFILLMENT_TIMEOUT', () => pm.expect(json.code).to.eql('FULFILLMENT_TIMEOUT'));"] } }]
        }
      ]
    },
    {
      "name": "03 - Rule Config and Validation Scenarios",
      "item": [
        {
          "name": "Create Journey for Rule Checks",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-request-id", "value": "{{requestId}}" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"currency\": \"USD\",\n  \"locale\": \"en-US\"\n}" },
            "url": "{{baseUrl}}/v1/checkout/journeys"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 201', () => pm.response.to.have.status(201));", "const json = pm.response.json();", "pm.environment.set('journeyId', json.data.id);"] } }]
        },
        {
          "name": "Step Conflict - Review Submit Too Early",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-request-id", "value": "{{requestId}}" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"payload\": {\n    \"confirmed\": true\n  }\n}" },
            "url": "{{baseUrl}}/v1/checkout/journeys/{{journeyId}}/steps/review-submit"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 409', () => pm.response.to.have.status(409));", "const json = pm.response.json();", "pm.test('error code is STEP_CONFLICT', () => pm.expect(json.code).to.eql('STEP_CONFLICT'));"] } }]
        },
        {
          "name": "Rule-style Invalid Postal",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-request-id", "value": "{{requestId}}" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payload\": {\n    \"firstName\": \"Sam\",\n    \"lastName\": \"Taylor\",\n    \"line1\": \"101 Main St\",\n    \"city\": \"Austin\",\n    \"state\": \"TX\",\n    \"postalCode\": \"ABC\",\n    \"country\": \"US\"\n  }\n}"
            },
            "url": "{{baseUrl}}/v1/checkout/journeys/{{journeyId}}/steps/shipping-address"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 400', () => pm.response.to.have.status(400));", "const json = pm.response.json();", "pm.test('error code is VALIDATION_ERROR', () => pm.expect(json.code).to.eql('VALIDATION_ERROR'));"] } }]
        },
        {
          "name": "Rule-style NY Cash On Delivery",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
