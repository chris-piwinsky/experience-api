                "url": "{{baseUrl}}/v1/checkout/journeys/{{journeyId}}/steps/review-submit"
              }
            }
          ]
        },
        {
          "name": "Submit - Payment Declined",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-request-id", "value": "{{requestId}}" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "url": "{{baseUrl}}/v1/checkout/journeys/{{journeyId}}/submit"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 409', () => pm.response.to.have.status(409));", "const json = pm.response.json();", "pm.test('error code is PAYMENT_DECLINED', () => pm.expect(json.code).to.eql('PAYMENT_DECLINED'));"] } }]
        },
        {
          "name": "Submit - Inventory Unavailable",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-request-id", "value": "{{requestId}}" },
              { "key": "x-correlation-id", "value": "{{correlationId}}" }
            ],
            "url": "{{baseUrl}}/v1/checkout/journeys/{{journeyId}}/submit"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 409', () => pm.response.to.have.status(409));", "const json = pm.response.json();", "pm.test('error code is INVENTORY_UNAVAILABLE', () => pm.expect(json.code).to.eql('INVENTORY_UNAVAILABLE'));"] } }]
        },
