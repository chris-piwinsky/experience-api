meta {
  name: Create Journey
  type: http
  seq: 12
}

post {
  url: "{{baseUrl}}/v1/checkout/journeys"
  body: json
  auth: none
}

headers {
  Content-Type: "application/json"
  x-request-id: "{{requestId}}"
  x-correlation-id: "{{correlationId}}"
}

body:json {
  {
    "customerId": "{{customerId}}",
    "currency": "USD",
    "locale": "en-US"
  }
}
