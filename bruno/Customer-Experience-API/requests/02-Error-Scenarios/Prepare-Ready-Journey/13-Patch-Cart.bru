meta {
  name: Patch Cart
  type: http
  seq: 13
}

patch {
  url: "{{baseUrl}}/v1/checkout/journeys/{{journeyId}}/steps/cart"
  body: json
  auth: none
}

headers {
  Content-Type: "application/json"
  x-request-id: "{{requestId}}"
  x-correlation-id: "{{correlationId}}"
}

body:json {
  {
    "payload": {
      "items": [
        { "sku": "SKU-100", "quantity": 1 }
      ],
      "totalAmount": 129.99
    }
  }
}
